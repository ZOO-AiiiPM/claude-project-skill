{
  "//": "复制成 settings.local.json 后：1) 把 autoMemoryDirectory 改为当前项目的绝对路径 2) 如不想启用 journal 提醒 hook 可删 hooks 段",
  "autoMemoryDirectory": "/绝对路径/到项目/.claude/memory",
  "permissions": {
    "allow": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/journal-turn-counter.sh"
          }
        ]
      }
    ]
  }
}
